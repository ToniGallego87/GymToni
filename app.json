{
  "expo": {
    "name": "GymToni",
    "slug": "gymtoni",
    "icon": "./assets/icon.png",
    "version": "0.2.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.gymtrack.app"
    },
    "android": {
      "package": "com.gymtrack.app",
      "permissions": []
    },
    "web": {
      "favicon": "./assets/icon.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": false,
          "asyncRoutes": true,
          "root": "./app"
        }
      ]
    ],
    "scheme": "gymtrack",
    "extra": {
      "eas": {
        "projectId": "66ab349f-bf74-4fa9-b4af-263fc087d9b5"
      }
    }
  }
}
