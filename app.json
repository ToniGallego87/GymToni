{
  "expo": {
    "name": "GymTrack",
    "slug": "gymtrack",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTabletMode": true,
      "bundleIdentifier": "com.gymtrack.app"
    },
    "android": {
      "package": "com.gymtrack.app",
      "permissions": []
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": false,
          "asyncRoutes": true,
          "root": "./app"
        }
      ]
    ],
    "scheme": "gymtrack"
  }
}
