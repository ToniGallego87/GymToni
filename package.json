{
  "name": "gymtrack",
  "version": "0.1.0",
  "private": true,
  "description": "MVP app para registrar entrenamientos de gimnasio de forma rápida",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "start:clean": "powershell -ExecutionPolicy Bypass -File ./scripts/start-expo.ps1",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "eas-build": "eas build --platform all",
    "format": "prettier --write .",
    "type-check": "tsc --noEmit",
    "postinstall": "patch-package"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "1.23.1",
    "@react-navigation/bottom-tabs": "~6.6.1",
    "@react-navigation/native": "~6.1.18",
    "@react-navigation/native-stack": "~6.10.1",
    "expo": "~51.0.39",
    "expo-blur": "~13.0.3",
    "expo-constants": "~16.0.2",
    "expo-document-picker": "~12.0.2",
    "expo-file-system": "~17.0.1",
    "expo-font": "~12.0.10",
    "expo-linking": "~6.3.1",
    "expo-notifications": "~0.28.19",
    "expo-router": "~3.5.23",
    "expo-sharing": "~12.0.1",
    "expo-splash-screen": "~0.27.7",
    "expo-status-bar": "~1.12.1",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "react-native": "0.74.5",
    "react-native-gesture-handler": "~2.16.2",
    "react-native-paper": "~5.11.7",
    "react-native-reanimated": "~3.10.1",
    "react-native-safe-area-context": "4.10.5",
    "react-native-screens": "3.31.1",
    "react-native-web": "~0.19.10"
  },
  "devDependencies": {
    "@babel/core": "^7.24.0",
    "@types/react": "~18.2.79",
    "babel-plugin-module-resolver": "^5.0.2",
    "babel-preset-expo": "~11.0.10",
    "patch-package": "^8.0.1",
    "prettier": "~3.0.0",
    "typescript": "~5.3.0"
  },
  "resolutions": {
    "react-native": "0.74.5",
    "react": "18.2.0"
  },
  "expo": {
    "plugins": [
      [
        "expo-router",
        {
          "origin": false,
          "asyncRoutes": true,
          "root": "./app"
        }
      ]
    ]
  }
}
