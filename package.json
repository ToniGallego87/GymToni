{
  "name": "gymtrack",
  "version": "0.1.0",
  "private": true,
  "description": "MVP app para registrar entrenamientos de gimnasio de forma rápida",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "eas-build": "eas build --platform all",
    "format": "prettier --write .",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "expo": "^51.0.0",
    "expo-font": "^12.0.0",
    "expo-router": "^3.0.0",
    "expo-splash-screen": "^0.27.0",
    "expo-status-bar": "^1.12.0",
    "react": "18.2.0",
    "react-native": "0.74.5",
    "react-native-paper": "^5.11.0",
    "react-native-gesture-handler": "^2.14.0",
    "react-native-reanimated": "^3.8.0",
    "react-native-safe-area-context": "^4.8.0",
    "react-native-screens": "^3.30.0",
    "@react-navigation/native": "^6.1.0",
    "@react-navigation/bottom-tabs": "^6.5.0",
    "@react-navigation/native-stack": "^6.9.0"
  },
  "devDependencies": {
    "@types/react": "^18.2.79",
    "@types/react-native": "^0.73.0",
    "typescript": "^5.3.0",
    "prettier": "^3.0.0"
  },
  "expo": {
    "plugins": [
      [
        "expo-router",
        {
          "origin": false,
          "asyncRoutes": true,
          "ignoreEntryPoint": true,
          "root": "./app"
        }
      ]
    ]
  }
}
